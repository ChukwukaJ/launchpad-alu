rules_version = '2';

// Security model summary (explain this in the demo — it's a rubric point):
//
// - Every write is tied to request.auth.uid; nobody can write another
//   user's data or impersonate another startup.
// - "startups" can only be marked verified/rejected by a doc whose role
//   field (in /users/{uid}) equals "admin" — startups cannot self-verify.
// - "opportunities" can only be created by the owning, VERIFIED startup —
//   enforced with a get() lookup against the startup doc, not just trusted
//   client-side UI gating.
// - "applications" are created only by the applying student and can only be
//   status-updated by the owning startup — students can't self-accept.
// - "bookmarks" and "notifications" are private per-user subcollections.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    // ---------- users ----------
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;

      match /bookmarks/{opportunityId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---------- startups ----------
    match /startups/{startupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Owners may edit their own profile fields but never their own
      // verification status; only an admin may flip `status`.
      allow update: if (isSignedIn() &&
                          resource.data.ownerUid == request.auth.uid &&
                          request.resource.data.status == resource.data.status)
                       || isAdmin();
      allow delete: if false;
    }

    // ---------- opportunities ----------
    match /opportunities/{opportunityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.ownerUid == request.auth.uid &&
        get(/databases/$(database)/documents/startups/$(request.resource.data.startupId)).data.status == 'verified';
      allow update, delete: if isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.ownerUid == request.auth.uid;
    }

    // ---------- applications ----------
    match /applications/{applicationId} {
      allow read: if isSignedIn() &&
        (resource.data.studentUid == request.auth.uid ||
         get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.ownerUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.studentUid == request.auth.uid;
      // Only the receiving startup can move the status pipeline forward.
      allow update: if isSignedIn() &&
        get(/databases/$(database)/documents/startups/$(resource.data.startupId)).data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // ---------- notifications ----------
    match /notifications/{notificationId} {
      allow read, update: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if isSignedIn(); // written server-side-equivalent via batched writes
      allow delete: if false;
    }
  }
}
